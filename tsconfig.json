{
  "extends": "@tsconfig/recommended/tsconfig.json",
  "include": ["src/**/*", "types"],
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },
    "target": "esnext",
    "module": "nodenext",
    "typeRoots": ["node_modules/@types", "types"],
    "rootDir": "src",
    "outDir": "dist",
    "lib": ["dom", "esnext"],
    "skipLibCheck": true,
    "types": ["node"]
  }
}
